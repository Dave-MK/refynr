# Copy to .env.local and fill in.

# Required for AI insights (the deterministic cleansing works without it).
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the model used for AI insights.
# REFYNR_AI_MODEL=claude-opus-4-8

# ── Accounts + AI-insight metering (Supabase) ────────────────────────────────
# Without these, the app still runs but AI insights are open (no login/quota).
# Create a project at supabase.com, run supabase/migrations/0001_auth_metering.sql,
# then copy these from Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Server-only — bypasses RLS to record usage. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Developer API (/api/clean) ───────────────────────────────────────────────
# Optional. Unset = the route is disabled (404). Set = callers must send
# `Authorization: Bearer <this value>`. The web UI does not use this route.
# REFYNR_API_KEY=
